# Copy this file to .env and fill in your values

# ── Server ────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────────────
# Local (Windows): use 127.0.0.1 NOT localhost (fixes IPv6 issue)
MONGODB_URI=mongodb://127.0.0.1:27017/perfume-vault

# Atlas (production):
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/perfume-vault?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_hex_string
JWT_EXPIRE=30d

# ── Client URL ────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5000
